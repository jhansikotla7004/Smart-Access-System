{
    ST7735_FillScreen(ST7735_BLACK);

    ST7735_FillRectangle(0, 0, 128, 26, ST7735_RED);
    ST7735_WriteString(20, 7, "SECURITY", Font_7x10, ST7735_WHITE, ST7735_RED);

