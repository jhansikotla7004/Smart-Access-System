#include "stm32l4xx_hal.h"
#include "st7735/st7735.h"
#include "st7735/fonts.h"
#include <string.h>
#include <stdio.h>

/*
Display: SCK PA5, SDA PA7, CS PA4, DC PA6, RST PA0
Buzzer: PA1
Keypad: PB0 PB4 PB5 PB6 PA8 PA9 PA10
UART2: PA2 TX, PA3 RX
*/

UART_HandleTypeDef huart2;
SPI_HandleTypeDef hspi1;

#define BUZZER_PORT GPIOA
#define BUZZER_PIN  GPIO_PIN_1
#define MAX_ATTEMPTS 3

GPIO_TypeDef* keyPorts[7] = {
    GPIOB, GPIOB, GPIOB, GPIOB, GPIOA, GPIOA, GPIOA
};

uint16_t keyPins[7] = {
    GPIO_PIN_0, GPIO_PIN_4, GPIO_PIN_5, GPIO_PIN_6,
    GPIO_PIN_8, GPIO_PIN_9, GPIO_PIN_10
};

typedef struct {
    int pinA;
    int pinB;
    char key;
} KeyPair;

KeyPair keyPairs[12] = {
    {2,3,'1'}, {2,5,'3'}, {1,2,'2'},
    {7,3,'4'}, {7,1,'5'}, {5,7,'6'},
    {3,6,'7'}, {1,6,'8'}, {5,6,'9'},
    {3,4,'*'}, {1,4,'0'}, {5,4,'#'}
};

int pinCount = 0;
int wrongAttempts = 0;
uint8_t systemLocked = 0;

void SystemClock_Config(void);
void MX_USART2_UART_Init(void);
void MX_BUZZER_GPIO_Init(void);
void MX_SPI1_Init(void);

void UART_Print(char *msg);
void Beep(uint16_t duration_ms);

void Set_Pin_Output_Low(int index);
void Set_Pin_InputPullup(int index);
char Get_Key_From_Pair(int a, int b);
char Keypad_Read(void);

void Screen_Home(void);
void Screen_Pin(void);
void Screen_Granted(void);
void Screen_Denied(void);
void Screen_Locked(void);
void Screen_Cleared(void);

void Access_Granted(void);
void Access_Denied(void);
void System_Locked(void);

int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_USART2_UART_Init();
    MX_BUZZER_GPIO_Init();
    MX_SPI1_Init();

    ST7735_Unselect();
    HAL_Delay(100);
    ST7735_Init();

    Screen_Home();

    UART_Print("\r\n================================\r\n");
    UART_Print("     SMART ACCESS SYSTEM\r\n");
    UART_Print("================================\r\n");
    UART_Print("Enter PIN: ");

    Beep(120);
    HAL_Delay(180);
    Beep(120);

    while (1)
    {
        char key = Keypad_Read();

        if (key != 0 && systemLocked == 0)
        {
            if (key == '*')
            {
                pinCount = 0;
                Screen_Cleared();
                UART_Print("\r\nPIN cleared\r\n");
                UART_Print("Enter PIN: ");
                Beep(80);
                HAL_Delay(1500);
                Screen_Home();
            }
            else if (key == '1')
            {
                pinCount++;

                UART_Print("* ");

                Screen_Pin();
                Beep(80);

                if (pinCount >= 3)
                {
                    Access_Granted();
                    pinCount = 0;
                    Screen_Home();
                    UART_Print("\r\nEnter PIN: ");
                }
            }
            else
            {
                pinCount = 0;
                Access_Denied();

                if (systemLocked == 0)
                {
                    Screen_Home();
                    UART_Print("Enter PIN: ");
                }
            }
        }

        HAL_Delay(50);
    }
}

