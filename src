/* ---------------- ACCESS LOGIC ---------------- */

void Access_Granted(void)
{
    wrongAttempts = 0;

    UART_Print("\r\n\r\n>>> ACCESS GRANTED <<<\r\n");

    Screen_Granted();

    Beep(140);
    HAL_Delay(250);
    Beep(140);
    HAL_Delay(250);
    Beep(140);

    HAL_Delay(6000);
}

void Access_Denied(void)
{
    wrongAttempts++;

    UART_Print("\r\n\r\n>>> ACCESS DENIED <<<\r\n");

    char msg[40];
    sprintf(msg, "Wrong attempt: %d/3\r\n", wrongAttempts);
    UART_Print(msg);

    Screen_Denied();

    Beep(400);
    HAL_Delay(250);
    Beep(400);

    if (wrongAttempts >= MAX_ATTEMPTS)
    {
        System_Locked();
    }
    else
    {
        HAL_Delay(4000);
    }
}

void System_Locked(void)
{
    systemLocked = 1;

    UART_Print("\r\n!!! SYSTEM LOCKED !!!\r\n");
    UART_Print("Reset board to restart.\r\n");

    Screen_Locked();

    while (1)
    {
        Beep(300);
        HAL_Delay(500);
    }
}

/* ---------------- BUZZER ---------------- */

void Beep(uint16_t duration_ms)
{
    uint32_t start = HAL_GetTick();

    while ((HAL_GetTick() - start) < duration_ms)
    {
        HAL_GPIO_WritePin(BUZZER_PORT, BUZZER_PIN, GPIO_PIN_SET);
        HAL_Delay(5);
        HAL_GPIO_WritePin(BUZZER_PORT, BUZZER_PIN, GPIO_PIN_RESET);
        HAL_Delay(5);
    }
}

/* ---------------- KEYPAD ---------------- */

char Keypad_Read(void)
{
    for (int drive = 0; drive < 7; drive++)
    {
        for (int i = 0; i < 7; i++)
        {
            if (i == drive)
                Set_Pin_Output_Low(i);
            else
                Set_Pin_InputPullup(i);
        }

        HAL_Delay(2);

        for (int read = 0; read < 7; read++)
        {
            if (read == drive)
                continue;

            if (HAL_GPIO_ReadPin(keyPorts[read], keyPins[read]) == GPIO_PIN_RESET)
            {
                char key = Get_Key_From_Pair(drive + 1, read + 1);

                while (HAL_GPIO_ReadPin(keyPorts[read], keyPins[read]) == GPIO_PIN_RESET)
                    HAL_Delay(5);

                HAL_Delay(30);
                return key;
            }
        }
    }

    return 0;
}

char Get_Key_From_Pair(int a, int b)
{
    for (int i = 0; i < 12; i++)
    {
        if ((keyPairs[i].pinA == a && keyPairs[i].pinB == b) ||
            (keyPairs[i].pinA == b && keyPairs[i].pinB == a))
        {
            return keyPairs[i].key;
        }
    }

    return '?';
}

void Set_Pin_Output_Low(int index)
{
    if (keyPorts[index] == GPIOA &&
       (keyPins[index] == GPIO_PIN_0 ||
        keyPins[index] == GPIO_PIN_4 ||
        keyPins[index] == GPIO_PIN_5 ||
        keyPins[index] == GPIO_PIN_6 ||
        keyPins[index] == GPIO_PIN_7))
    {
        return;
    }

    GPIO_InitTypeDef g = {0};

    if (keyPorts[index] == GPIOA)
        __HAL_RCC_GPIOA_CLK_ENABLE();

    if (keyPorts[index] == GPIOB)
        __HAL_RCC_GPIOB_CLK_ENABLE();

    g.Pin = keyPins[index];
    g.Mode = GPIO_MODE_OUTPUT_PP;
    g.Pull = GPIO_NOPULL;
    g.Speed = GPIO_SPEED_FREQ_LOW;

    HAL_GPIO_Init(keyPorts[index], &g);
    HAL_GPIO_WritePin(keyPorts[index], keyPins[index], GPIO_PIN_RESET);
}

void Set_Pin_InputPullup(int index)
{
    if (keyPorts[index] == GPIOA &&
       (keyPins[index] == GPIO_PIN_0 ||
        keyPins[index] == GPIO_PIN_4 ||
        keyPins[index] == GPIO_PIN_5 ||
        keyPins[index] == GPIO_PIN_6 ||
        keyPins[index] == GPIO_PIN_7))
    {
        return;
    }

    GPIO_InitTypeDef g = {0};

    if (keyPorts[index] == GPIOA)
        __HAL_RCC_GPIOA_CLK_ENABLE();

    if (keyPorts[index] == GPIOB)
        __HAL_RCC_GPIOB_CLK_ENABLE();

    g.Pin = keyPins[index];
    g.Mode = GPIO_MODE_INPUT;
    g.Pull = GPIO_PULLUP;

    HAL_GPIO_Init(keyPorts[index], &g);
}

/* ---------------- UART / SPI / CLOCK ---------------- */

void UART_Print(char *msg)
{
    HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);
}

void MX_BUZZER_GPIO_Init(void)
{
    GPIO_InitTypeDef g = {0};

    __HAL_RCC_GPIOA_CLK_ENABLE();

    g.Pin = BUZZER_PIN;
    g.Mode = GPIO_MODE_OUTPUT_PP;
    g.Pull = GPIO_NOPULL;
    g.Speed = GPIO_SPEED_FREQ_LOW;

    HAL_GPIO_Init(BUZZER_PORT, &g);
    HAL_GPIO_WritePin(BUZZER_PORT, BUZZER_PIN, GPIO_PIN_RESET);
}

void MX_SPI1_Init(void)
{
    GPIO_InitTypeDef g = {0};

    __HAL_RCC_GPIOA_CLK_ENABLE();
    __HAL_RCC_SPI1_CLK_ENABLE();

    g.Pin = GPIO_PIN_5 | GPIO_PIN_7;
    g.Mode = GPIO_MODE_AF_PP;
    g.Pull = GPIO_NOPULL;
    g.Speed = GPIO_SPEED_FREQ_VERY_HIGH;
    g.Alternate = GPIO_AF5_SPI1;
    HAL_GPIO_Init(GPIOA, &g);

    g.Pin = GPIO_PIN_0 | GPIO_PIN_4 | GPIO_PIN_6;
    g.Mode = GPIO_MODE_OUTPUT_PP;
    g.Pull = GPIO_NOPULL;
    g.Speed = GPIO_SPEED_FREQ_HIGH;
    HAL_GPIO_Init(GPIOA, &g);

    hspi1.Instance = SPI1;
    hspi1.Init.Mode = SPI_MODE_MASTER;
    hspi1.Init.Direction = SPI_DIRECTION_2LINES;
    hspi1.Init.DataSize = SPI_DATASIZE_8BIT;
    hspi1.Init.CLKPolarity = SPI_POLARITY_LOW;
    hspi1.Init.CLKPhase = SPI_PHASE_1EDGE;
    hspi1.Init.NSS = SPI_NSS_SOFT;
    hspi1.Init.BaudRatePrescaler = SPI_BAUDRATEPRESCALER_2;
    hspi1.Init.FirstBit = SPI_FIRSTBIT_MSB;
    hspi1.Init.TIMode = SPI_TIMODE_DISABLE;
    hspi1.Init.CRCCalculation = SPI_CRCCALCULATION_DISABLE;

    HAL_SPI_Init(&hspi1);
}

